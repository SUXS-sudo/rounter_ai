# ============================================================
# LLM API Configuration
# ============================================================
# Provider: 'openai' for most models (DeepSeek/LongCat/MiMo), 'anthropic' for MiMo Anthropic protocol
ROUTE_PLANNER_LLM_PROVIDER=openai

# API Key (get from your provider)
ROUTE_PLANNER_MIMO_API_KEY=your-api-key-here

# API Base URL
# DeepSeek:    https://api.deepseek.com
# LongCat:     https://api.longcat.chat/openai
# SiliconFlow: https://api.siliconflow.cn/v1
# MiMo官方:    https://token-plan-cn.xiaomimimo.com/v1
ROUTE_PLANNER_MIMO_BASE_URL=https://api.longcat.chat/openai

# Model identifier
# DeepSeek:    deepseek-chat
# LongCat:     LongCat-Flash-Chat
# MiMo:        mimo-v2.5-pro
# SiliconFlow: XiaomiMiMo/MiMo-7B-RL
ROUTE_PLANNER_MIMO_MODEL=LongCat-Flash-Chat

# Generation parameters
ROUTE_PLANNER_MIMO_TEMPERATURE=0.3
ROUTE_PLANNER_MIMO_MAX_TOKENS=4096
